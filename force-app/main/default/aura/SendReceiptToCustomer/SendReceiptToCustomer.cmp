<aura:component controller="ReceiptCustomerSendController"
                implements="flexipage:availableForRecordHome,force:hasRecordId,flexipage:availableForAllPageTypes"
                access="global">

    <aura:attribute name="recordId" type="Id" />
    <aura:attribute name="showModal" type="Boolean" default="false" />
    <aura:attribute name="isLoading" type="Boolean" default="false" />
    <aura:attribute name="receiptOptions" type="List" />
    <aura:attribute name="selectedReceiptId" type="String" />
    <aura:attribute name="emailContent" type="String" />
    <aura:attribute name="subject" type="String" />
    <aura:attribute name="buttonstate" type="Boolean" default="false" />
    <aura:attribute name="previewUrl" type="String" />
    <aura:attribute name="filesIDS" type="List" default="[]" />
    <aura:attribute name="uploadedFiles" type="List" default="[]" />

    <aura:html tag="style">
    .slds-modal__container{
        max-width: 90rem !important;
        width: 100% !important;
    }
    .slds-modal__content{
        height: 70vh;
        overflow-y: auto;
    }
    .toggle-center-wrap{
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
    }
    .upload-box-wrap{
        border: 1px solid #d8dde6;
        border-radius: 0.25rem;
        background: #fafaf9;
    }
    .upload-box-header{
        background: #f3f2f2;
        padding: 0.6rem 1rem;
        font-weight: 600;
        border-bottom: 1px solid #d8dde6;
    }
    .upload-box-body{
        padding: 1rem;
    }
    .upload-help-text{
        margin-bottom: 0.75rem;
        color: #444;
        text-align: center;
    }
    .upload-center-wrap{
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
    }
    .preview-frame{
        width: 100%;
        height: 500px;
        border: 1px solid #d8dde6;
        border-radius: 0.25rem;
    }
    .uploaded-file-row{
        border: 1px solid #e5e5e5;
        border-radius: 0.25rem;
        background: #fff;
        padding: 0.5rem 0.75rem;
        margin-bottom: 0.5rem;
    }
    .uploaded-file-name{
        vertical-align: middle;
        margin-left: 0.4rem;
        text-decoration: none;
    }
</aura:html>

    <div class="slds-grid slds-grid_align-end slds-p-around_x-small">
        <lightning:button variant="brand"
                          label="Send Email"
                          title="Send Email"
                          onclick="{!c.openModal}" />
    </div>

    <aura:if isTrue="{!v.showModal}">
        <section role="dialog" tabindex="-1" class="slds-modal slds-fade-in-open" aria-modal="true">
            <div class="slds-modal__container">
                <header class="slds-modal__header">
                    <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse"
                            onclick="{!c.closeModal}">
                        <lightning:icon iconName="utility:close" size="small" alternativeText="Close" />
                    </button>
                    <h2 class="slds-text-heading_medium slds-hyphenate">Send Receipt To Customer</h2>
                </header>

                <div class="slds-modal__content slds-p-around_medium">

                    <div class="slds-m-bottom_medium">
                        <lightning:select name="receiptSelect"
                                          label="Select Receipt"
                                          value="{!v.selectedReceiptId}"
                                          onchange="{!c.handleReceiptChange}">
                            <option value="">-- Select Receipt --</option>
                            <aura:iteration items="{!v.receiptOptions}" var="rec">
                                <option value="{!rec.receiptId}">{!rec.receiptName}</option>
                            </aura:iteration>
                        </lightning:select>
                    </div>

                    <div class="slds-m-bottom_medium">
                        <div class="toggle-center-wrap">
                            <lightning:buttonStateful
                                labelWhenOff="Email View"
                                labelWhenOn="Document View"
                                labelWhenHover="Switch View"
                                iconNameWhenOff="utility:email"
                                iconNameWhenOn="utility:page"
                                iconNameWhenHover="utility:swap"
                                state="{!v.buttonstate}"
                                onclick="{!c.handleToggle}" />
                        </div>
                    </div>

                    <div class="slds-m-bottom_medium">
                        <aura:if isTrue="{!v.buttonstate == false}">
                            <lightning:inputRichText aura:id="emailContent"
                                                     value="{!v.emailContent}"
                                                     placeholder="Review and edit email content" />
                            <aura:set attribute="else">
                                <aura:if isTrue="{!not(empty(v.previewUrl))}">
                                    <iframe src="{!v.previewUrl}" class="preview-frame"></iframe>
                                    <aura:set attribute="else">
                                        <div class="slds-text-color_weak slds-p-around_medium slds-border">
                                            Select a receipt to preview the PDF.
                                        </div>
                                    </aura:set>
                                </aura:if>
                            </aura:set>
                        </aura:if>
                    </div>

                    <aura:if isTrue="{!v.buttonstate == false}">
                        <div class="upload-box-wrap slds-m-top_medium">
                            <div class="upload-box-header">Files</div>
                            <div class="upload-box-body">
                                <div class="upload-help-text">
                                   
                                </div>

                                <div class="upload-center-wrap">
                                    <lightning:fileUpload
                                        label="Upload Files"
                                        name="fileUploader"
                                        multiple="true"
                                        accept=".pdf,.png,.jpg,.jpeg,.doc,.docx,.xls,.xlsx"
                                        recordId="{!v.recordId}"
                                        onuploadfinished="{!c.handleFileUpload}" />
                                </div>

                                <aura:if isTrue="{!not(empty(v.uploadedFiles))}">
                                    <div class="slds-m-top_medium">
                                        <div class="slds-text-title_bold slds-m-bottom_small">Uploaded Documents</div>

                                        <aura:iteration items="{!v.uploadedFiles}" var="file">
                                            <div class="uploaded-file-row slds-grid slds-grid_vertical-align-center">
                                                <lightning:icon iconName="utility:attach" size="x-small" />
                                                <a href="{!file.url}"
                                                   target="_blank"
                                                   class="uploaded-file-name slds-text-link">
                                                    {!file.name}
                                                </a>
                                            </div>
                                        </aura:iteration>
                                    </div>
                                </aura:if>
                            </div>
                        </div>
                    </aura:if>

                    <aura:if isTrue="{!v.isLoading}">
                        <lightning:spinner alternativeText="Loading..." size="medium" />
                    </aura:if>
                </div>

                <footer class="slds-modal__footer">
                    <lightning:button variant="neutral"
                                      label="Cancel"
                                      onclick="{!c.closeModal}" />
                    <lightning:button variant="brand"
                                      label="Send To Customer"
                                      onclick="{!c.sendEmail}"
                                      disabled="{!empty(v.selectedReceiptId) || v.isLoading}" />
                </footer>
            </div>
        </section>
        <div class="slds-backdrop slds-backdrop_open"></div>
    </aura:if>
</aura:component>