<aura:component implements="force:lightningQuickActionWithoutHeader,force:hasRecordId"
                access="global"
                controller="DocumentandEmailController">

    <aura:attribute name="recordId" type="Id"/>
    <aura:attribute name="booking" type="Booking__c"/>
    <aura:attribute name="pdfUrl" type="String"/>
    <aura:attribute name="isSending" type="Boolean" default="false"/>

    <force:recordData aura:id="bookingRecord"
                      recordId="{!v.recordId}"
                      targetFields="{!v.booking}"
                      fields="Project_Type__c, Email__c"
                      recordUpdated="{!c.doInit}"/>

    <div class="slds-modal__container" style="width: 100% !important; max-width: 80rem !important;">
        <header class="slds-modal__header">
            <h2 class="slds-text-heading_medium">Preview &amp; Send Key Handover</h2>
        </header>

        <div class="slds-modal__content slds-p-around_medium" style="height: 600px;">
            <div class="slds-grid slds-gutters slds-height_full">
                <div class="slds-col slds-size_2-of_3" style="border-right: 1px solid #ddd;">
                    <aura:if isTrue="{!not(empty(v.pdfUrl))}">
                        <iframe src="{!v.pdfUrl}" width="100%" height="500px" style="border: none;"></iframe>
                        <aura:set attribute="else">
                            <div class="slds-align_absolute-center">Loading Preview...</div>
                        </aura:set>
                    </aura:if>
                </div>

                <div class="slds-col slds-size_1-of_3">
                    <div class="slds-text-title_caps slds-m-bottom_small">Recipient Details</div>
                    <p><strong>To:</strong> {!v.booking.Email__c}</p>
                    <p><strong>Project Type:</strong> {!v.booking.Project_Type__c}</p>
                    
                    <div class="slds-m-top_large">
                        <p class="slds-text-color_weak">Please review the document on the left before sending.</p>
                    </div>
                </div>
            </div>
        </div>

        <footer class="slds-modal__footer">
            <lightning:button label="Cancel" onclick="{!c.handleCancel}"/>
            <lightning:button label="Send Email" variant="brand" onclick="{!c.handleSend}" disabled="{!v.isSending}"/>
        </footer>
    </div>
</aura:component>