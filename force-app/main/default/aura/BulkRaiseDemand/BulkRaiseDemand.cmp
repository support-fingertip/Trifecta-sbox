<aura:component controller="BulkRaiseDemandController" 
                implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" 
                access="global">
    <aura:attribute name="inc" type="String" />
    <lightning:notificationsLibrary aura:id="notifLib" />
    <aura:attribute name="masterPaymentScheduleId" type="String" />
    <aura:attribute name="bookingRecords" type="Booking__c[]" />
    <aura:attribute name="showNextCmp" type="boolean" default="false" />
    <aura:registerEvent name="raiseDemandEvent" type="c:raiseDemandEvent"/>
    <aura:attribute name="paymentScheduleId" type="Id" />
    <aura:attribute name="Bookid" type="Id" />
    <aura:attribute name="Leadid" type="id"/>
    <aura:attribute name="showRaiseAll" type="Boolean" default="false"/>
    <aura:attribute name="isLoading" type="Boolean" default="false"/>
    <aura:attribute name="files" type="List" default="[]" />
    <aura:attribute name="selectedRecords" type="List" default="[]" />
    <aura:attribute name="selectedFileIds" type="List" default="[]" />
    <aura:attribute name="filesIDS" type="List" />
    <aura:attribute name="allChecked" type="Boolean" default="false" />

    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    
    <lightning:card>
        <aura:if isTrue="{!v.isLoading}">
            <div class="slds-size_1-of-1 slds-p-horizontal_small">
                <c:loadingScreen size="3" />
            </div>
            <aura:set attribute="else">
                
                <!-- Action Bar -->
                <div style="padding: 12px 16px; background: #ffffff; border-bottom: 1px solid #dddbda; display: flex; align-items: center; justify-content: space-between;">
                    <lightning:button 
                                      label="Raise All" 
                                      onclick="{!c.raiseAllDemands}" 
                                      variant="brand"
                                      iconName="utility:upload"
                                      iconPosition="left" />
                    <span style="font-size: 14px; font-weight: 600; color: #3e3e3c;">Booking Records</span>
                </div>
                
                <!-- Table -->
                <div style="padding: 8px; overflow-x: auto;">
                    <table class="slds-table slds-table_bordered slds-no-row-hover" style="width: 100%; table-layout: fixed; font-size: 12px;">
                        <thead>
                            <tr style="background: #f3f2f2;">
                                <th scope="col" style="padding: 8px 6px; width: 60px; white-space: nowrap;">
                                    <lightning:input type="checkbox" label="" 
                                                     checked="{!v.allChecked}" 
                                                     onchange="{!c.toggleSelectAll}" />
                                </th>
                                <th scope="col" style="padding: 8px 6px; width: 40px; font-weight: 700; color: #3e3e3c;">S/No</th>
                                <th scope="col" style="padding: 8px 6px; width: 80px; font-weight: 700; color: #3e3e3c;">Booking</th>
                                <th scope="col" style="padding: 8px 6px; width: 140px; font-weight: 700; color: #3e3e3c;">Customer Name</th>
                                <th scope="col" style="padding: 8px 6px; width: 160px; font-weight: 700; color: #3e3e3c;">Email</th>
                                <th scope="col" style="padding: 8px 6px; width: 100px; font-weight: 700; color: #3e3e3c;">Project</th>
                                <th scope="col" style="padding: 8px 6px; width: 80px; font-weight: 700; color: #3e3e3c;">Unit Name</th>
                                <th scope="col" style="padding: 8px 6px; width: 100px; font-weight: 700; color: #3e3e3c; text-align: center;">Milestone Amt</th>
                                <th scope="col" style="padding: 8px 6px; width: 90px; font-weight: 700; color: #3e3e3c; text-align: center;">Prev. Pending</th>
                                <th scope="col" style="padding: 8px 6px; width: 90px; font-weight: 700; color: #3e3e3c; text-align: center;">Received</th>
                                <th scope="col" style="padding: 8px 6px; width: 90px; font-weight: 700; color: #3e3e3c; text-align: center;">Grand Total</th>
                                <th scope="col" style="padding: 8px 6px; width: 100px; font-weight: 700; color: #3e3e3c; text-align: center;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <aura:iteration items="{!v.bookingRecords}" var="bookingWrapper" indexVar="index">
                                <tr style="background: white; border-bottom: 1px solid #e5e5e5;">
                                    <td data-label="Select" style="padding: 8px 6px;">
                                        <lightning:input type="checkbox" 
                                                         aura:id="bookingCheckbox" 
                                                         value="{!bookingWrapper}"
                                                         onchange="{!c.toggleCheckbox}"
                                                         checked="{!bookingWrapper.selected}"
                                                         disabled="{!or(empty(bookingWrapper.booking.Email__c),bookingWrapper.demandRaised)}"
                                                         name="{!index}"/>
                                    </td>
                                    <td data-label="S/No" style="padding: 8px 6px; color: #5e5e5c; font-size: 12px;">{!index + 1}</td>
                                    <td data-label="Booking" style="padding: 8px 6px;">
                                        <a href="{!'/lightning/r/Booking__c/' + bookingWrapper.booking.Id + '/view'}" target="_blank" style="color: #0176d3; text-decoration: none; font-weight: 500; font-size: 12px;">
                                            {!bookingWrapper.booking.Name}
                                        </a>
                                    </td>
                                    <td style="padding: 8px 6px;">
                                        <td data-label="Lead Name" style="border: none; padding: 0; color: #3e3e3c; font-size: 12px; word-break: break-word;">
                                            {!bookingWrapper.booking.S__c}. {!bookingWrapper.booking.Applicant_Name__c}
                                        </td>        
                                    </td>
                                    <td data-label="Email" style="padding: 8px 6px; color: #3e3e3c; font-size: 11px; word-break: break-all;">{!bookingWrapper.booking.Email__c}</td>
                                    <td data-label="Project" style="padding: 8px 6px; color: #3e3e3c; font-size: 12px;">{!bookingWrapper.booking.Project1__r.Name}</td>
                                    <td data-label="Unit Name" style="padding: 8px 6px;">
                                        <a href="{!'/lightning/r/Plot__c/' + bookingWrapper.unitId + '/view'}" target="_blank" style="color: #0176d3; text-decoration: none; font-weight: 500; font-size: 12px;">
                                            {!bookingWrapper.booking.Plot__r.Name}
                                        </a>
                                    </td>
                                    <td data-label="Current Milestone Amount" style="padding: 8px 6px; text-align: center; color: #3e3e3c; font-size: 12px;">{!bookingWrapper.totalPaymentAmount}</td>
                                    <td data-label="Previous Pendings" style="padding: 8px 6px; text-align: center; color: #e07b00; font-size: 12px; font-weight: 500;">{!bookingWrapper.previousDemandRaisedPending}</td>
                                    <td data-label="Received Amount" style="padding: 8px 6px; text-align: center; color: #2e844a; font-size: 12px; font-weight: 500;">{!bookingWrapper.totalAmountPaid}</td>
                                    <td data-label="Grand Total" style="padding: 8px 6px; text-align: center; color: #0176d3; font-size: 12px; font-weight: 600;">{!bookingWrapper.grandTotal}</td>
                                    <td data-label="Raise Demand" style="padding: 8px 6px; text-align: center;">
                                        <lightning:button 
                                                          label="Raise Demand" 
                                                          onclick="{!c.raiseDemand}" 
                                                          variant="brand"
                                                          disabled="{!or(empty(bookingWrapper.booking.Email__c),bookingWrapper.demandRaised)}"
                                                          value="{!bookingWrapper}" />
                                    </td>
                                </tr>
                            </aura:iteration>
                        </tbody>
                    </table>
                </div>
                
                <!-- Modal -->
                <aura:if isTrue="{!v.showNextCmp}">
                    <section role="dialog" tabindex="-1" aria-modal="true" aria-labelledby="modal-heading-01" class="slds-modal slds-fade-in-open">
                        <div class="slds-modal__container">
                            <c:RaiseDemandLetter recordId="{!v.Bookid}" visible="{!v.showNextCmp}"/> 
                        </div>
                    </section>
                    <div class="slds-backdrop slds-backdrop_open" role="presentation"></div>
                </aura:if>
                
            </aura:set>
        </aura:if>
    </lightning:card>
    

    <aura:if isTrue="{!v.showRaiseAll}">
        <c:RaiseAllModalPopup selectedRecords="{!v.selectedRecords}" selectedFileIds="{!v.selectedFileIds}" showPopup="{!v.showRaiseAll}"/>
    </aura:if>

</aura:component>