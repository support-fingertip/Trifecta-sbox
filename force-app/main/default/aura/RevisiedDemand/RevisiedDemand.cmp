<aura:component controller="RaiseDemandEmailController" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global">
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    <aura:attribute name="paymentScheduleId" type="Id" />
    <aura:attribute name="recordId" type="Id" />
    <aura:attribute name="vfPage" type="string" />
    <aura:attribute name="showPdf" type="boolean" default="false" />
    <aura:attribute name="canRaiseDemand" type="boolean" default="false" />
    
    <aura:attribute name="Bookid" type="Id" />
    <aura:attribute name="includeInterest" type="String" default="false"/>
    <aura:attribute name="ObjName" type="String" />
    <aura:attribute name="recId" type="id"/>
    <aura:attribute name="visible" type="Boolean" default="false"/>
    <aura:attribute name="disableVar" type="boolean" default="false"/>
    <aura:attribute name="fromBulkDemand" type="boolean" default="false" />
    <aura:attribute name="bookingRecords" type="Booking__c[]" />
    
    <aura:attribute name="recordIdsList" type="List" />
    <aura:attribute name="emailContentMap" type="Map" />
    <aura:attribute name="contentDocumentIdsMap" type="Map" />
    <aura:attribute name="buttonstate" type="Boolean" default="false"/>
    <aura:attribute name="emailContent" type="String" />
    <aura:attribute name="subject" type="String" />
    
    <aura:attribute name="filesIDS" type="List" />
    <aura:attribute name="lastPymtSchedule" type="boolean" default="false" />
    <aura:handler name="fileUploadEvent" event="c:fileUploadEvent" action="{!c.handleFileUpload}" />
    
    <aura:html tag="style">
        .slds-modal__container{ 
        max-width: 90rem !important;
        width:100% !important;
        } 
        .slds-modal__content
        {
        	min-height: fit-content;
        }
        .panel.slds-modal > .modal-container {
        width: 75%;
        max-width: 70rem;
        }
    </aura:html>
    
    <section role="dialog" tabindex="-1" class="slds-modal slds-fade-in-open" aria-modal="true">
        <div class="slds-modal__container">
            <header class="slds-modal__header">
                <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" onclick="{!c.close}">
                    <lightning:icon iconName="utility:close" size="small" alternativeText="Close" />
                </button>
                <h2 class="slds-text-heading_medium slds-hyphenate">Revised DEMAND LETTER</h2>
            </header>
            
            <div class="slds-modal__content slds-p-around_small" id="modal-content-id-1">
                <div class="slds-grid slds-p-bottom_x-small slds-grid_vertical-align-center slds-align_absolute-center">
                    <lightning:buttonStateful
                                              labelWhenOff="Document View"
                                              labelWhenOn="Email View"
                                              labelWhenHover="Email"
                                              iconNameWhenOff="utility:page"
                                              iconNameWhenOn="utility:email"
                                              iconNameWhenHover="utility:close"
                                              state="{! v.buttonstate }"
                                              onclick="{! c.handleClick }"
                                              />
                </div>
                
                <div class="slds-grid slds-gutters">
                    <div class="slds-size_1-of-1 slds-p-around_medium">
                        <!-- Show Email content when viewMode is 'email' -->
                        <aura:if isTrue="{!v.buttonstate == false}">
                            <lightning:inputRichText class="custom-textarea" aura:id="emailContent"
                                                     placeholder="Review and edit email content"
                                                     value="{!v.emailContent}" />
                            
                            <c:photoUploadComponent recordId="{!v.recordId}" filesIds="{!v.filesIDS}" />
                        </aura:if>
                        
                        <!-- Show Document when viewMode is 'document' -->
                        <aura:if isTrue="{!v.buttonstate == true}">
                            <iframe src="{!'/apex/DemandNote?Id=' + v.recordId + '&amp;reminderType=REVISED%20DEMAND%20NOTE'}" 
                                    width="100%" 
                                    height="450px">
                            </iframe>
                        </aura:if>
                    </div>
                </div>
                
            </div>
            
            <footer class="slds-modal__footer">
                <button class="slds-button slds-button_neutral" onclick="{!c.close}">Cancel</button>
                <aura:if isTrue="{!v.canRaiseDemand == false}">
                    <button class="slds-button slds-button_brand" onclick="{!c.sendEmail}">Send Email</button>
                </aura:if>
            </footer>
        </div>
    </section>
    
    <!-- BACKDROP: This grays out the background behind the modal -->
    <div class="slds-backdrop slds-backdrop_open"></div>
    
</aura:component>