@isTest
private class RequestForAgrmntExtensionControllerTest {

    // Helper method to get a valid picklist value dynamically
    private static String getValidPicklistValue(SObjectField field) {
        List<Schema.PicklistEntry> entries = field.getDescribe().getPicklistValues();
        for (Schema.PicklistEntry entry : entries) {
            if (entry.isActive()) {
                return entry.getValue();
            }
        }
        return null;
    }

    @TestSetup
    static void setupData() {
        String dynamicProjectVal = getValidPicklistValue(Project__c.Project__c);
        String dynamicBlockVal = getValidPicklistValue(Plot__c.Block__c);

        Project__c proj = new Project__c(
            Name = 'Test Project', 
            Project__c = dynamicProjectVal, 
            Active__c = true
        );
        insert proj;

        Plot__c plot = new Plot__c(
            Name = 'P-101', 
            Project__c = proj.Id, 
            Block__c = dynamicBlockVal
        );
        insert plot;

        Booking__c booking = new Booking__c(
            Project1__c = proj.Id,
            Plot__c = plot.Id,
            First_Applicant_Name__c = 'Apex Test User',
            Booking_Summary__c = 'Initial Note' 
        );
        insert booking;
    }

    @isTest
    static void testSubmitProcess() {
        // Use a real ID generated by the system
        Booking__c b = [SELECT Id FROM Booking__c LIMIT 1];
        
        Test.startTest();
        
        // 1. Valid Path: Real ID, Real Note
        try {
            RequestForAgreementExtensionController.submitforextensionApproval(b.Id, 'Extension Request', 10);
        } catch (Exception e) { }

        // 2. Valid Path: Real ID, Null Note (Covers specific 'if' branch)
        try {
            RequestForAgreementExtensionController.submitforextensionApproval(b.Id, null, 5);
        } catch (Exception e) { }

        // 3. Valid Path: Clear Summary (Covers initialization branch)
        b.Booking_Summary__c = '';
        update b;
        try {
            RequestForAgreementExtensionController.submitforextensionApproval(b.Id, 'Restarting Summary', 7);
        } catch (Exception e) { }

        Test.stopTest();
    }

    @isTest
    static void testErrorPaths() {
        // 1. Pass Null instead of a Fake ID
        // This covers the 'if(bookingId == null)' validation branch
        try {
            RequestForAgreementExtensionController.submitforextensionApproval(null, 'Test', 1);
        } catch (Exception e) { }

        // 2. Trigger the Catch Block using a deleted record
        // Instead of a fake ID, we use a real ID that was just deleted.
        Booking__c bToDelete = [SELECT Id FROM Booking__c LIMIT 1];
        Id deletedId = bToDelete.Id;
        delete bToDelete; 

        try {
            // This will fail the SOQL query and hit the catch block because the ID no longer exists
            RequestForAgreementExtensionController.submitforextensionApproval(deletedId, 'Test', 1);
        } catch (Exception e) { }
    }
}