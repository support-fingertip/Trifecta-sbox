<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Agreement_Status_Validation_CRM_Executiv</fullName>
    <active>true</active>
    <errorConditionFormula>ISCHANGED(Stage_Status__c)
&amp;&amp; TEXT(Stage_Status__c) = &apos;Completed&apos;
&amp;&amp; TEXT(Stage__c) = &apos;Agreement&apos;
&amp;&amp; (TEXT(Agreement_Status__c) &lt;&gt; 	&apos;Executed &amp; Registered&apos;)</errorConditionFormula>
    <errorMessage>Please update the agreement status to &quot;Executed &amp; Registered&quot; before marking the Agreement stage as completed.</errorMessage>
</ValidationRule>
