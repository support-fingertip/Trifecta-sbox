<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Sales_Deed_Upload_Validation</fullName>
    <active>true</active>
    <errorConditionFormula>ISCHANGED(Stage_Status__c)
&amp;&amp; TEXT(Stage_Status__c) = &apos;Completed&apos;
&amp;&amp; (TEXT(Stage__c) = &apos;Registration&apos; || TEXT(Stage__c) = &apos;Land Registration&apos;)
&amp;&amp; (Signed_Sales_Deed_Uploaded__c = False )</errorConditionFormula>
    <errorMessage>Please upload Signed Sales Deed before marking the Registration stage as completed</errorMessage>
</ValidationRule>
