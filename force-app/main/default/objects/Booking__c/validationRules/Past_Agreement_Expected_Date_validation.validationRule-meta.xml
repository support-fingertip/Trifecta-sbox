<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Past_Agreement_Expected_Date_validation</fullName>
    <active>true</active>
    <errorConditionFormula>ISCHANGED(Agreement_Expected_Date__c) &amp;&amp;
Agreement_Expected_Date__c &lt; TODAY()</errorConditionFormula>
    <errorDisplayField>Agreement_Expected_Date__c</errorDisplayField>
    <errorMessage>Agreement Expected Date must be a future date.</errorMessage>
</ValidationRule>
